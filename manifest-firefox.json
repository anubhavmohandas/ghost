{
  "manifest_version": 2,
  "name": "GHOST",
  "version": "5.1.0",
  "description": "General Handler of Stored Templates — silently fills any form with your saved profiles. Personal, credentials, custom fields & security payloads.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "GHOST — General Handler of Stored Templates"
  },
  "background": {
    "scripts": ["background/background-ff.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "<all_urls>"
  ],
  "commands": {
    "trigger-autofill": {
      "suggested_key": {
        "default": "Ctrl+Shift+F"
      },
      "description": "Trigger autofill on current page"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ghost@anubhavmohandas",
      "strict_min_version": "109.0"
    }
  }
}
